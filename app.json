{
  "expo": {
    "name": "card-vault",
    "jsEngine": "hermes",
    "slug": "card-vault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cardvault",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cardvault.app",
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.cardvault.app",
      "icon": "./assets/images/icon.png",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/foreground.png",
        "monochromeImage": "./assets/images/foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Card Vault to use Face ID to unlock your cards securely."
        }
      ],
      "expo-sharing",
      "expo-localization",
      [
        "expo-widgets",
        {
          "groupIdentifier": "group.com.cardvault.app",
          "widgets": [
            {
              "name": "CardVaultWidget",
              "displayName": "Card Vault",
              "description": "Tap to unlock Card Vault",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "accessoryCircular",
                "accessoryRectangular"
              ]
            }
          ]
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9d8e61a7-4112-4d9c-80c8-d5e690ff0da8"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9d8e61a7-4112-4d9c-80c8-d5e690ff0da8"
    }
  }
}
