# Sentry - get your DSN from https://sentry.io → Project Settings → Client Keys (DSN)
# Copy this file to .env and fill in your values
EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# For EAS Build source map uploads (optional - add to EAS project secrets)
# Without these, builds succeed but Sentry stack traces will be minified
# SENTRY_AUTH_TOKEN=your_org_auth_token
# SENTRY_ORG=your_org_slug
# SENTRY_PROJECT=your_project_slug
